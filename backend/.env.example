# Copy this file to .env and adjust as needed. Everything here is local-only.
# There are deliberately NO cloud endpoints, API keys, or URLs in this system.

# --- MQTT (the local stand-in for the mine mesh) ---
# Set USE_MQTT=false for the live-demo safety net: the backend then generates
# level values on an internal timer instead of talking to a broker. Same
# /levels output either way, so the demo never depends on Mosquitto being up.
USE_MQTT=true
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_BASE_TOPIC=mine
MQTT_KEEPALIVE=60

# --- Levels ---
# Comma-separated level ids; leave blank to use the full layout from mine.py
# (400L, 800L, 1200L, 1600L). Topics become mine/<level>/gas, e.g. mine/1200L/gas.
LEVELS=
# The level driven by the drill-and-blast cycle (post-blast CO/NO2 surge, then
# ventilation clears it for re-entry). Must be one of the levels.
ACTIVE_BLAST_LEVEL=1200L

# --- Trend / history ---
# Number of recent readings kept per level for trend + rolling-average work.
HISTORY_SIZE=12

# --- Gas limits (DEMO values; real legal limits differ, see docs/) ---
# Methane, % by volume.
METHANE_WARNING=1.0
METHANE_DANGER=1.5
METHANE_EARLY_WARNING=0.9
# Carbon monoxide, ppm (governs post-blast re-entry).
CO_WARNING=25
CO_DANGER=100
# Nitrogen dioxide, ppm.
NO2_WARNING=3
NO2_DANGER=5
# Carbon dioxide, % by volume.
CO2_WARNING=0.5
CO2_DANGER=1.5
# Oxygen, % by volume (LOW is the hazard).
O2_WARNING=19.5
O2_DANGER=18.0

# --- Ventilation-on-demand + post-blast model (demo tuning) ---
METHANE_CLIMB_RATE=0.16
MITIGATION_RATE=0.11
BLAST_CO_PEAK=220
BLAST_NO2_PEAK=8
BLAST_CLEAR_RATE=0.18
BLAST_REST_SECONDS=8

# --- Simulator ---
PUBLISH_INTERVAL=1.0

# --- Offline data historian (time-based logging to disk) ---
# Telemetry + events are written to dated JSONL files here, and app.log rotates
# daily. Path is relative to the backend folder unless absolute.
LOG_DIR=logs
LOG_RETENTION_DAYS=14
HISTORIAN_ENABLED=true
LOG_LEVEL=INFO

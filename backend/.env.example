# Copy this file to .env and adjust as needed. Everything here is local-only.
# There are deliberately NO cloud endpoints, API keys, or URLs in this system.

# --- MQTT (the local stand-in for the mine mesh) ---
# Set USE_MQTT=false for the live-demo safety net: the backend then generates
# zone values on an internal timer instead of talking to a broker. Same /zones
# output either way, so the demo never depends on Mosquitto being up.
USE_MQTT=true
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_BASE_TOPIC=mine
MQTT_KEEPALIVE=60

# --- Zones ---
# Comma-separated zone ids. Topics become mine/<zone>/gas.
ZONES=zone1,zone2,zone3,zone4
# The one zone whose methane slowly climbs toward danger, so the demo shows a
# clear trend (yellow -> red). Must be one of ZONES.
CLIMBING_ZONE=zone3

# --- Trend / thresholds (DEMO values; real legal limits differ, see docs/) ---
# Number of recent readings kept per zone for trend detection.
HISTORY_SIZE=10
# Methane danger threshold in % by volume (demo value).
METHANE_DANGER=1.5
# Methane warning threshold in % by volume (demo value).
METHANE_WARNING=1.0
# CO thresholds in ppm (demo values).
CO_WARNING=35
CO_DANGER=100

# --- Simulator ---
# Seconds between published readings.
PUBLISH_INTERVAL=1.0
